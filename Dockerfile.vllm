# ============================================================
# vLLM 공식 이미지를 베이스로 사용 (CUDA 12.9 호환)
# - vLLM Hugging Face 모델 운영 전용
# - OpenClaude (npm 콘솔 모드만) 포함
# - Ollama, gRPC(bun+소스)는 basic 이미지에서 사용
# ============================================================
FROM vllm/vllm-openai:cu129-nightly

# ============================================================
# 환경변수
# ============================================================
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Seoul
ENV LANG=ko_KR.UTF-8
ENV LANGUAGE=ko_KR:ko
ENV LC_ALL=ko_KR.UTF-8

# OpenClaude default mode (OpenAI 호환 모드)
# Anthropic native 호출 시에만 사용자가 USE_ANTHROPIC=1 입력
ENV CLAUDE_CODE_USE_OPENAI=1

# ============================================================
# 최소 시스템 패키지
# ============================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl git ca-certificates locales \
    && locale-gen ko_KR.UTF-8 \
    && rm -rf /var/lib/apt/lists/*

# ============================================================
# Node.js 22 (OpenClaude 실행 환경)
# ============================================================
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# ============================================================
# 캐시 무효화 인자 (build.yml에서 매 빌드마다 다른 값 전달)
# ============================================================
ARG CACHEBUST=1

# ============================================================
# OpenClaude (npm 글로벌 설치) - 콘솔 모드용
# CACHEBUST로 매 빌드마다 최신 버전 설치
# ============================================================
RUN echo "Cache bust: ${CACHEBUST}" \
    && npm install -g @gitlawb/openclaude \
    && npm cache clean --force

# ============================================================
# Hugging Face 모델 캐시 기본 경로
# ============================================================
ENV HF_HOME=/workspace/huggingface_cache

# ============================================================
# Workspace
# ============================================================
RUN mkdir -p /workspace
WORKDIR /workspace

# ============================================================
# Exposed ports
# - 8000: vLLM OpenAI-compatible API server
# ============================================================
EXPOSE 8000

# ============================================================
# Entrypoint (vLLM 기본 entrypoint를 OpenClaude entrypoint로 대체)
# ============================================================
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]